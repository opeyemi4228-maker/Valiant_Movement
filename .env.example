# ---- Database (Neon) ----
# Create a project at https://neon.tech and copy the pooled connection string.
# Must include ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# ---- Email (Resend) ----
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=""
# Verified sender. For quick local testing you can use the Resend sandbox sender:
EMAIL_FROM="Valiant Movement <onboarding@resend.dev>"

# ---- App ----
# Public base URL used to build verification links (no trailing slash).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Calls (WebRTC TURN) ----
# STUN alone can't traverse many NATs/firewalls, so calls between members on
# different networks need a TURN relay. Leave blank to use a free public TURN
# (fine for testing); set your own for production reliability (Metered, Twilio,
# Cloudflare Calls…). Comma-separate multiple URLs.
NEXT_PUBLIC_TURN_URL=""
NEXT_PUBLIC_TURN_USERNAME=""
NEXT_PUBLIC_TURN_CREDENTIAL=""

# ---- Security ----
# Secret used to HMAC-hash NINs before storage. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NIN_HASH_SECRET="change-me-to-a-long-random-string"

# ---- Wallet payments (Monnify) ----
# Powers the Finance dashboard. Sign up at https://monnify.com — sandbox keys
# are free and instant; switch MONNIFY_BASE_URL + keys to go live later, no
# code change needed. Leave ALL of these blank and the Finance dashboard
# still shows balance/history, just with deposits/withdrawals disabled.

# 1) DEPOSITS — these three alone are enough to turn deposits on (hosted
#    checkout: card, bank transfer, USSD). Contract code is from your
#    Monnify dashboard → Settings → Contract.
MONNIFY_BASE_URL="https://sandbox.monnify.com"
MONNIFY_API_KEY=""
MONNIFY_SECRET_KEY=""
MONNIFY_CONTRACT_CODE=""

# Register this webhook URL in the Monnify dashboard (Settings → Webhooks)
# — it's what confirms BOTH deposits and withdrawals server-side:
#   <NEXT_PUBLIC_APP_URL>/api/payments/monnify/webhook

# 2) WITHDRAWALS (optional, on top of the above) — the Monnify wallet
#    payouts are disbursed FROM. Leave blank to keep deposits working while
#    withdrawals stay disabled. Also ask Monnify support to disable 2FA on
#    this wallet, or fully-automated withdrawals will sit waiting for manual
#    OTP approval in the Monnify dashboard instead of paying out instantly.
MONNIFY_DISBURSEMENT_ACCOUNT=""
